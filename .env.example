# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database
MONGO_URI=mongodb://localhost:27017/healthcare_db

# AI/LLM Services (Proxy Mode)
# ------------------------------------------------------
# 1. Standard OpenAI: https://api.openai.com/v1
# 2. Local Proxy (Extension/Server): http://localhost:8080/v1 (adjust port)
# 3. OpenRouter (Free/Cheap): https://openrouter.ai/api/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# ------------------------------------------------------

# File Upload
UPLOAD_FOLDER=./uploads
MAX_UPLOAD_SIZE=52428800

# OCR Configuration
OCR_ENABLED=True
TESSERACT_PATH=/usr/bin/tesseract  # On Windows: C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Email Configuration (for alerts)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Analytics
ENABLE_ANALYTICS=True

# Cache
CACHE_REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
